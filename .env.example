# =============================================================================
# Entri Bulk Sharing Links — environment variables
#
# All variables here are OPTIONAL. The frontend now collects credentials and
# the sharing config from the user, so a public deploy needs no env vars.
#
# Copy to `.env` (gitignored) only if you want server-side defaults.
# =============================================================================

# OPTIONAL: server-side default applicationId / secret.
# If a user submits the form with these fields blank, the backend will fall
# back to these values. Useful for single-tenant or internal deploys.
ENTRI_APPLICATION_ID=
ENTRI_SECRET=

# OPTIONAL: pre-fill the applicationId field in the UI with the env value.
# Set to "true" only on internal deployments. NEVER enable on a public deploy
# — it would leak your applicationId to every visitor.
ENTRI_PREFILL_APP_ID=false

# OPTIONAL: default sharing flow ("connect" or "sell"). User can change in UI.
ENTRI_SHARING_FLOW=connect

# OPTIONAL: API base URL (only override for testing/staging).
ENTRI_BASE_URL=https://api.goentri.com

# OPTIONAL: HTTP client timeout (seconds) per request to Entri.
HTTP_TIMEOUT=30

# OPTIONAL: Limits.
MAX_DOMAINS_PER_REQUEST=1000
MAX_UPLOAD_BYTES=2097152
MAX_CONFIG_BYTES=65536

# OPTIONAL: Flask debug mode (NEVER enable in production).
FLASK_DEBUG=false
